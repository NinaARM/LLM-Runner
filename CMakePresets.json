{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 27 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": { 
        "LLM_FRAMEWORK": "llama.cpp",
        "BUILD_DEBUG": false,
        "BUILD_LLM_TESTING": true,
        "BUILD_BENCHMARK": false,
        "BUILD_JNI_LIB": true
      }
    },
    {
      "name": "native",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/scripts/cmake/toolchains/native-dispatch.cmake"
    },
    {
      "name": "x-android-aarch64",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/scripts/cmake/toolchains/x-android-aarch64.cmake",
      "cacheVariables": {
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-33"
      }
    },
    {
      "name": "x-linux-aarch64",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/scripts/cmake/toolchains/x-linux-aarch64.cmake"
    }
  ]
}
